{
  "name": "dune-3v3",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "verify": "node scripts/verify-all.mjs",
    "verify:all": "node scripts/verify-all.mjs",
    "debug:browser": "node scripts/browser-debug.mjs",
    "debug:browser:help": "node scripts/browser-debug.mjs --help",
    "debug:browser:scenarios": "node scripts/browser-debug.mjs --list-scenarios",
    "debug:browser:headed": "node scripts/browser-debug.mjs --headed --keep-open",
    "debug:browser:manual": "node scripts/browser-debug.mjs --headed --keep-open --scenario manual",
    "debug:game": "node scripts/browser-debug.mjs --headed --keep-open --scenario manual --out artifacts/qa/browser-debug-manual",
    "debug:game:smoke": "node scripts/browser-debug.mjs --scenario manual --capture-smoke --out artifacts/qa/browser-debug-manual-smoke --no-trace",
    "sync:cards": "node scripts/sync-dune-catalog.mjs",
    "sync:card-images": "node scripts/sync-dune-catalog.mjs --download-images",
    "verify:alliances": "node scripts/verify-alliances.mjs",
    "verify:app-high-council": "node scripts/verify-app-high-council.mjs",
    "verify:battle-icons": "node scripts/verify-battle-icons.mjs",
    "verify:board-requirements": "node scripts/verify-board-requirements.mjs",
    "verify:board-location-effects": "node scripts/verify-board-location-effects.mjs",
    "verify:board-rules": "node scripts/verify-board-rules.mjs",
    "verify:board-spaces": "node scripts/verify-board-spaces.mjs",
    "verify:card-effect-specs": "node scripts/verify-card-effect-specs.mjs",
    "verify:combat-intrigues": "node scripts/verify-combat-intrigues.mjs",
    "verify:conflict-awards": "node scripts/verify-conflict-awards.mjs",
    "verify:contracts": "node scripts/verify-contracts.mjs",
    "verify:endgame": "node scripts/verify-endgame.mjs",
    "verify:influence": "node scripts/verify-influence.mjs",
    "verify:imperium-cards": "node scripts/verify-imperium-cards.mjs",
    "verify:intrigues": "node scripts/verify-intrigues.mjs",
    "verify:leaders": "node scripts/verify-leaders.mjs",
    "verify:maker-spice": "node scripts/verify-maker-spice.mjs",
    "verify:objectives": "node scripts/verify-objectives.mjs",
    "verify:player-setup": "node scripts/verify-player-setup.mjs",
    "verify:sandworms": "node scripts/verify-sandworms.mjs",
    "verify:sietch-tabr": "node scripts/verify-sietch-tabr.mjs",
    "verify:spy-posts": "node scripts/verify-spy-posts.mjs",
    "verify:starter-decks": "node scripts/verify-starter-decks.mjs",
    "verify:starter-decks-devastating-assault": "node scripts/verify-starter-decks-devastating-assault.mjs",
    "verify:team-trade": "node scripts/verify-team-trade.mjs",
    "verify:throne-row": "node scripts/verify-throne-row.mjs"
  },
  "dependencies": {
    "lucide-react": "0.554.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "5.9.3",
    "vite": "7.3.3"
  },
  "devDependencies": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "playwright": "1.60.0"
  }
}
